# Upstash Redis (required for data storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# OpenAI (required for chat and summarization)
OPENAI_API_KEY=

# Optional: comma-separated Clerk user IDs allowed to use AI (chat, summarize, voice/image). Empty = no one.
ALLOWED_OPENAI_USER_IDS=

# Clerk (from https://dashboard.clerk.com - API keys)
# Clerk supports keyless mode: run without keys to start developing immediately
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Optional: where to send users for sign-in/sign-up and after auth (defaults work with app routes)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# Dev: user ID for local testing when not signed in (optional)
DEV_USER_ID=dev-user
NEXT_PUBLIC_DEV_USER_ID=dev-user

# E2E: set when running dev server for Playwright tests (bypasses auth)
# E2E_BYPASS_AUTH=true
